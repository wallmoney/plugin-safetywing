{
  "id": "wallmoney-safetywing",
  "org": "wallmoney",
  "repo": "plugin-safetywing",
  "name": "SafetyWing",
  "description": "Choose SafetyWing nomad insurance, review country availability, collect member details, and prefill payment from Wall Money.",
  "version": "0.2.1",
  "icon": "icon.svg",
  "bundle": "bundle.js",
  "permissions": [
    "storage.get",
    "storage.set",
    "events.onPaymentExecuted",
    "payments.openPrefilledPayment",
    "ui.navigate",
    "ui.notify"
  ],
  "entry": "default",
  "mota": {
    "infopanel": {
      "description": "Choose coverage, check country availability, and pay from Wall Money.",
      "primary": {
        "label": "Manage cover",
        "action": {
          "type": "navigate",
          "href": "/marketplace/wallmoney/plugin-safetywing"
        }
      },
      "secondary": {
        "label": "Country map",
        "action": {
          "type": "navigate",
          "href": "https://safetywing.com/nomad-care-map"
        }
      }
    }
  }
}
